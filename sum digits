import java.util.*;

public class sum_digits {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int count = 0;

        while (a > 0) {
            int b = a % 10;
            a /= 10;
            count = count + b;
        }
        System.out.println(count);
    }
}
